<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.cortex.updater</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/git</string>
        <string>-C</string>
        <string>CORTEX_HOME/cortex</string>
        <string>pull</string>
        <string>origin</string>
        <string>main</string>
    </array>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>1</integer>
        <key>Minute</key>
        <integer>30</integer>
    </dict>
    <key>StandardOutPath</key>
    <string>CORTEX_HOME/cortex/logs/updater.log</string>
    <key>StandardErrorPath</key>
    <string>CORTEX_HOME/cortex/logs/updater-error.log</string>
</dict>
</plist>
